<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DentaireApp.UI.Avalonia.ViewModels"
        xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Avalonia.Svg.Skia"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="DentaireApp.UI.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        MinWidth="1160"
        MinHeight="620"
        Title="ESPACE DENTAIRE">

    <Window.Styles>
        <Style Selector="TextBox.queue-search">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Padding" Value="10,6" />
            <!-- Fluent theme uses a larger default MinHeight; allow compact Height -->
            <Setter Property="MinHeight" Value="0" />
        </Style>
        <Style Selector="Button.queue-nav">
            <Setter Property="FontFamily" Value="'JetBrains Mono', 'Cascadia Mono', Consolas, 'Courier New', 'Liberation Mono', monospace" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="CornerRadius" Value="6" />
            <!-- Inset from inner Border; keep 0 here -->
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ClipToBounds" Value="False" />
        </Style>
        <!-- Do not set Padding here — it overrides Fluent TemplateBinding and breaks Button.Padding -->
        <Style Selector="Button.queue-nav /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.queue-nav-nouveau /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Border.queue-nav-shadow">
            <Setter Property="CornerRadius" Value="10" />
            <!--<Setter Property="BoxShadow" Value="0 4 12 0 #45000000" />-->
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="ClipToBounds" Value="False" />
        </Style>
        <Style Selector="Button.queue-nav-prev">
            <Setter Property="Background" Value="#B8B8B8" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Button.queue-nav-prev:pointerover">
            <Setter Property="Background" Value="#A3A3A3" />
        </Style>
        <Style Selector="Button.queue-nav-next">
            <Setter Property="Background" Value="#7A9E7E" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Button.queue-nav-next:pointerover">
            <Setter Property="Background" Value="#6A8E6E" />
        </Style>
        <Style Selector="Button.settings-gear">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="#DCE5DC" />
            <Setter Property="BorderBrush" Value="#A7B8A4" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Button.settings-gear:pointerover">
            <Setter Property="Background" Value="#D0DBCF" />
        </Style>
    </Window.Styles>

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid>
        <svg:Svg Path="/Assets/background.svg"
                 Stretch="Fill" />
        <TabControl Margin="0">
            <TabControl.Styles>
                <Style Selector="TabStrip">
                    <Setter Property="IsVisible" Value="False" />
                </Style>
            </TabControl.Styles>
            <TabItem Header="File d'attente">
                <!-- 2 columns: logo band | queue list area -->
                <Grid DataContext="{Binding Queue}"
                      Margin="24,52,24,0"
                      RowDefinitions="Auto,*"
                      RowSpacing="18"
                      ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="400" />
                        <ColumnDefinition Width="*" MinWidth="300" />
                    </Grid.ColumnDefinitions>
                    <!-- Column 0: intentionally empty (branding / tooth art on background.svg) -->
                    <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                            Background="Transparent"
                            IsHitTestVisible="False" />

                    <!-- Queue column -->
                    <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                            ClipToBounds="True"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">
                        <Grid RowDefinitions="Auto,*"
                              MaxWidth="980"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Stretch">
                            <Grid Grid.Row="0"
                                  Margin="0,0,0,12"
                                  ColumnDefinitions="*,Auto"
                                  ColumnSpacing="12"
                                  HorizontalAlignment="Stretch"
                                  MaxWidth="980">
                                <TextBox Grid.Column="0"
                                         Classes="queue-search"
                                         Watermark="Rechercher un patient"
                                         Text="{Binding SearchTerm}"
                                         MinHeight="0"
                                         Height="34"
                                         HorizontalAlignment="Stretch"
                                         VerticalContentAlignment="Center"
                                         HorizontalContentAlignment="Left" />
                                <Button Grid.Column="1"
                                        Classes="queue-nav queue-nav-nouveau"
                                        Content="Nouveau"
                                        Command="{Binding NouveauNumeroCommand}"
                                        MinHeight="0"
                                        Width="100"
                                        Height="34"
                                        FontSize="16"
                                        Padding="12,0"
                                        HorizontalAlignment="Right"
                                        HorizontalContentAlignment="Center"
                                        VerticalAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        Background="#2E4682"
                                        Foreground="White" />
                            </Grid>

                            <ListBox Grid.Row="1"
                                     ItemsSource="{Binding Items}"
                                     SelectedItem="{Binding SelectedItem}"
                                     HorizontalAlignment="Stretch"
                                     MaxWidth="980"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     DoubleTapped="OnQueueListDoubleTapped">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,10,9" />
                                <Setter Property="Background" Value="#00FFFFFF" />
                            </Style>
                            <Style Selector="ListBoxItem:selected">
                                <Setter Property="Background" Value="#2E4682" />
                            </Style>
                            <Style Selector="ListBoxItem:selected TextBlock">
                                <Setter Property="Foreground" Value="White" />
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Commencer la session" Click="OnQueueSetInProgressClick" />
                                <MenuItem Header="Terminer la session" Click="OnQueueSetDoneClick" />
                                <MenuItem Header="Remettre en attente" Click="OnQueueSetWaitingClick" />
                                <MenuItem Header="Annuler la session" Click="OnQueueSetCancelledClick" />
                                <MenuItem Header="Dossier du patient"
                                          IsVisible="False"
                                          Click="OnQueueDossierPatientClick" />
                            </ContextMenu>
                        </ListBox.ContextMenu>
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:QueueItemViewModel">
                                <Border Padding="13,9"
                                        CornerRadius="4"
                                        Background="{Binding CardBackground}"
                                        PointerPressed="OnQueueItemPointerPressed">
                                    <!-- Next accent | badge | patient info (flex) | gap | time -->
                                    <Grid ColumnDefinitions="Auto,42,*,20,Auto"
                                          ColumnSpacing="0">
                                        <Border Grid.Column="0"
                                                Width="{Binding NextAccentWidth}"
                                                MinWidth="0"
                                                CornerRadius="3,0,0,3"
                                                Background="{Binding NextAccentBackground}"
                                                VerticalAlignment="Stretch" />
                                        <Border Grid.Column="1"
                                                Width="40"
                                                Height="30"
                                                CornerRadius="4"
                                                Background="{Binding QueueNumberBoxBackground}">
                                            <TextBlock Text="{Binding Number}"
                                                       FontSize="15"
                                                       FontWeight="Bold"
                                                       Foreground="{Binding QueueNumberForeground}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="2"
                                                    Margin="12,0,0,0"
                                                    Spacing="2"
                                                    VerticalAlignment="Center">
                                            <Border Padding="8,2"
                                                    CornerRadius="10"
                                                    Background="{Binding StatusBackground}"
                                                    HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding StatusLabel}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding StatusForeground}" />
                                            </Border>
                                            <TextBlock Text="{Binding Nom}"
                                                       FontSize="17"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{Binding NameForeground}" />
                                        </StackPanel>
                                        <!-- Fixed spacer between name and time range -->
                                        <Panel Grid.Column="3" Background="Transparent" />
                                        <TextBlock Grid.Column="4"
                                                   Text="{Binding PredictedInterval}"
                                                   Margin="10,0,0,0"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   FontSize="14"
                                                   Foreground="{Binding TimeForeground}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                </Grid>
            </TabItem>

            <TabItem Header="Liste des patients">
                <Grid Margin="12"
                      ColumnDefinitions="400,*"
                      ColumnSpacing="16">
                    <!-- Left column intentionally empty so logo remains visible -->
                    <Border Grid.Column="0"
                            Background="Transparent"
                            IsHitTestVisible="False" />
                    <Grid Grid.Column="1"
                          RowDefinitions="Auto,*,Auto"
                          RowSpacing="10">
                        <TextBox Grid.Row="0"
                                 Classes="queue-search"
                                 Watermark="Rechercher par nom ou téléphone"
                                 Text="{Binding PatientListSearchTerm}"
                                 MinHeight="0"
                                 Height="34"
                                 HorizontalAlignment="Stretch"
                                 VerticalContentAlignment="Center"
                                 HorizontalContentAlignment="Left" />
                        <Border Grid.Row="1"
                                CornerRadius="14"
                                Background="Transparent"
                                BorderBrush="{DynamicResource Brush.Stroke.Gray}"
                                BorderThickness="1"
                                Padding="5"
                                ClipToBounds="True"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                UseLayoutRounding="True">
                            <Border CornerRadius="9"
                                    Background="#E2E9E0"
                                    BorderBrush="{DynamicResource Brush.Stroke.Gray}"
                                    BorderThickness="1"
                                    Padding="0"
                                    ClipToBounds="True"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch">
                                <DataGrid x:Name="PatientListDataGrid"
                                          Classes="dossier-grid patient-list-grid"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"
                                          ItemsSource="{Binding PatientList}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          BorderThickness="0"
                                          Background="Transparent"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Auto"
                                          CanUserSortColumns="True"
                                          PointerPressed="OnPatientListDataGridPointerPressed"
                                          DoubleTapped="OnPatientListDataGridDoubleTapped">
                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Supprimer le patient" Click="OnPatientListDeletePatientClick" />
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="N°"
                                                            Binding="{Binding Number}"
                                                            Width="80"
                                                            MinWidth="72" />
                                        <DataGridTextColumn Header="NOM"
                                                            Binding="{Binding Nom}"
                                                            Width="2*"
                                                            MinWidth="160" />
                                        <DataGridTextColumn Header="ÂGE"
                                                            Binding="{Binding Age}"
                                                            Width="80"
                                                            MinWidth="72" />
                                        <DataGridTextColumn Header="TÉLÉPHONE"
                                                            Binding="{Binding Telephone}"
                                                            Width="150"
                                                            MinWidth="148" />
                                        <DataGridTextColumn Header="ADRESSE"
                                                            Binding="{Binding Adresse}"
                                                            Width="3*"
                                                            MinWidth="120" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </Border>
                        <StackPanel Grid.Row="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Spacing="10"
                                    VerticalAlignment="Center">
                          <Button Content="Précédent"
                                  Command="{Binding PatientListPrevPageCommand}"
                                  Padding="12,6" />
                          <TextBlock Text="{Binding PatientListPageLabel}"
                                     VerticalAlignment="Center"
                                     Foreground="#2E4682"
                                     FontWeight="SemiBold" />
                          <Button Content="Suivant"
                                  Command="{Binding PatientListNextPageCommand}"
                                  Padding="12,6" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
        <Button Classes="settings-gear"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,8,12,0"
                Click="OnOpenSettingsClick"
                ToolTip.Tip="Paramètres">
            <svg:Svg Path="/Assets/gear.svg"
                     Width="18"
                     Height="18"
                     Stretch="Uniform" />
        </Button>
    </Grid>

</Window>
