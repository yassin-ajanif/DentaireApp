<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Avalonia.Svg.Skia"
        x:Class="DentaireApp.UI.Avalonia.Views.NewPatientDialog"
        Width="420"
        Height="300"
        WindowStartupLocation="CenterOwner"
        Title="Nouveau numéro">
  <Panel>
    <svg:Svg Path="/Assets/PatientListInfoBackground.svg"
             Stretch="Fill"
             Opacity="0.92"
             IsHitTestVisible="False" />
    <Grid Margin="16" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="Auto,*" RowSpacing="8" ColumnSpacing="8">
      <TextBlock Text="Nom" />
      <TextBox x:Name="NomTextBox" Grid.Column="1" />

      <TextBlock Grid.Row="1" Text="Âge" />
      <TextBox x:Name="AgeTextBox" Grid.Row="1" Grid.Column="1" />

      <TextBlock Grid.Row="2" Text="Adresse" />
      <TextBox x:Name="AdresseTextBox" Grid.Row="2" Grid.Column="1" />

      <TextBlock Grid.Row="3" Text="Téléphone" />
      <TextBox x:Name="TelephoneTextBox"
               Grid.Row="3"
               Grid.Column="1"
               Watermark="Ex. 0612345678 ou +212 612 345 678" />

      <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
        <Button Content="Annuler" Click="OnCancelClick" />
        <Button x:Name="SaveButton" Content="Enregistrer" Click="OnSaveClick" />
      </StackPanel>

      <TextBlock x:Name="FeedbackTextBlock"
                 Grid.Row="5"
                 Grid.ColumnSpan="2"
                 Foreground="IndianRed"
                 TextWrapping="Wrap" />
    </Grid>
  </Panel>
</Window>

