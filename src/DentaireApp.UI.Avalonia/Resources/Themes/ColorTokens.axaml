<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Color x:Key="ColorRaw.PrimaryBlue">#2E4682</Color>
  <Color x:Key="ColorRaw.PrimaryGreen">#7A9E7E</Color>
  <Color x:Key="ColorRaw.SurfaceFaintGreen">#E7EDE3</Color>
  <Color x:Key="ColorRaw.NeutralGray">#D9D9D9</Color>

  <SolidColorBrush x:Key="Color.Background.App" Color="{StaticResource ColorRaw.SurfaceFaintGreen}" />
  <SolidColorBrush x:Key="Color.Background.Card" Color="{StaticResource ColorRaw.NeutralGray}" Opacity="0.3" />
  <!-- Control outlines (inputs, grids) — primary green #7A9E7E -->
  <SolidColorBrush x:Key="Brush.Stroke.System" Color="{StaticResource ColorRaw.PrimaryGreen}" />
  <SolidColorBrush x:Key="Brush.Stroke.Disabled" Color="{StaticResource ColorRaw.NeutralGray}" />
  <SolidColorBrush x:Key="Color.Border.Default" Color="{StaticResource ColorRaw.PrimaryGreen}" />
  <SolidColorBrush x:Key="Color.Text.Primary" Color="{StaticResource ColorRaw.PrimaryBlue}" />
  <SolidColorBrush x:Key="Color.Text.Secondary" Color="{StaticResource ColorRaw.PrimaryGreen}" />
  <SolidColorBrush x:Key="Color.Action.Primary" Color="{StaticResource ColorRaw.PrimaryBlue}" />
  <SolidColorBrush x:Key="Color.Accent.Success" Color="{StaticResource ColorRaw.PrimaryGreen}" />
</ResourceDictionary>

